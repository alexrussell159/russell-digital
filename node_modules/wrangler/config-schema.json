{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "compatibility_date": { "type": "string" },
    "observability": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "directory": { "type": "string" }
      },
      "required": ["directory"]
    },
    "compatibility_flags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["name", "compatibility_date"]
}