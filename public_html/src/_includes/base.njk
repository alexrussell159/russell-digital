<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} - Russell Digital{% else %}Russell Digital{% endif %}</title>

  <!-- Basic SEO -->
<meta name="description" content="{% if description %}{{ description | truncate(160) }}{% else %}Russell Digital — Data-driven SEO strategies that turn traffic into revenue.{% endif %}">

  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="icon" href="/assets/russell-digital-favicon.png" type="image/png" />
</head>
<body>

  <div id="rd-header"></div>

  <main class="rd-pricing-page">
    {{ content | safe }}
  </main>

  <div id="rd-footer"></div>

  <script src="/js/loadComponents.js" defer></script>
</body>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "author": {
    "@type": "Person",
    "name": "{{ author | default('Alex Russell') }}"
  },
  "datePublished": "{{ date }}",
  "dateModified": "{{ updated | default(date) }}",
  "image": "{% if image %}{{ image }}{% else %}/assets/russell-digital-favicon.png{% endif %}",
  "publisher": {
    "@type": "Organization",
    "name": "Russell Digital",
    "logo": {
      "@type": "ImageObject",
      "url": "/assets/russell-digital-favicon.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ page.url | url }}"
  }
}
</script>

</html>

